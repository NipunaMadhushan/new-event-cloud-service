                        "pluginVersion": "4.19.0",
                        "queryType": "logs",
                        "rawSql": "SELECT\n  Timestamp as \"timestamp\",\n  Body as \"body\",\n  SeverityText as \"level\",\n  TraceId as \"traceID\",\n  ResourceAttributes,\n  ScopeAttributes,\n  LogAttributes\nFROM otel.otel_logs\nWHERE Timestamp >= $__fromTime AND Timestamp <= $__toTime\n  AND Body ILIKE '%cmm707%'\nORDER BY Timestamp DESC\nLIMIT 1000"
